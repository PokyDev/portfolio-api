# Copiar a .env y completar con valores reales. No versionar .env.

# Conexión a Postgres (ver docker-compose.yml en la raíz del proyecto)
DATABASE_URL="postgresql://portfolio:portfolio_dev@localhost:5432/portfolio_dev"

# Secreto compartido con Nginx (proxy_set_header X-Internal-Gateway) para
# bloquear el acceso directo a este servicio fuera del proxy. Generar uno
# propio por entorno, nunca reutilizar el de otro ambiente.
INTERNAL_GATEWAY_SECRET="changeme"

# Origen permitido para CORS. En desarrollo es el frontend Next.js local;
# en producción, el dominio real del frontend.
FRONTEND_URL="http://localhost:3000"
